commands:
  01_node_info:
    command: "echo 'Node.js info:' && node -v && npm -v"
    ignoreErrors: true
  02_install_dependencies:
    command: "npm install -g pm2 critters"
    ignoreErrors: true

files:
  "/opt/elasticbeanstalk/hooks/appdeploy/pre/50_npm_config.sh":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      echo "Setting npm configuration..."
      npm config set unsafe-perm true
      npm config set legacy-peer-deps true 